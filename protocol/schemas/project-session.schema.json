{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://localize-anything.dev/schemas/project-session.schema.json",
  "title": "Localize Anything Project Session Index",
  "type": "object",
  "required": ["protocol_version", "project_root", "updated_at", "latest_session_id", "sessions"],
  "properties": {
    "protocol_version": { "const": "0.1" },
    "project_root": { "type": "string", "minLength": 1 },
    "updated_at": { "type": ["string", "null"], "format": "date-time" },
    "latest_session_id": { "type": ["string", "null"] },
    "sessions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "protocol_version",
          "session_id",
          "run_id",
          "kind",
          "status",
          "updated_at",
          "source_locale",
          "target_locale",
          "operating_mode",
          "reference_policy",
          "selected_source_files",
          "run_directory"
        ],
        "properties": {
          "protocol_version": { "const": "0.1" },
          "session_id": { "type": "string", "minLength": 1 },
          "run_id": { "type": "string", "minLength": 1 },
          "kind": { "enum": ["localize_run", "agent_run"] },
          "status": { "type": "string", "minLength": 1 },
          "updated_at": { "type": "string", "format": "date-time" },
          "source_locale": { "type": "string", "minLength": 1 },
          "target_locale": { "type": "string", "minLength": 1 },
          "operating_mode": {
            "enum": ["blind_benchmark", "greenfield_localization", "existing_locale_maintenance", "rewrite_or_harmonization"]
          },
          "reference_policy": {
            "enum": ["blind", "style_only", "tm_assisted", "preserve_existing"]
          },
          "selected_source_files": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "run_directory": { "type": "string", "minLength": 1 },
          "artifacts": { "type": "object", "additionalProperties": true },
          "routing": { "type": "object", "additionalProperties": true },
          "summary": { "type": "object", "additionalProperties": true },
          "child_runs": { "type": "object", "additionalProperties": true },
          "next_actions": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
