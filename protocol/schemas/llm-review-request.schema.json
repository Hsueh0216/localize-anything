{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://localize-anything.dev/schemas/llm-review-request.schema.json",
  "title": "Localize Anything LLM Review Request",
  "type": "object",
  "required": [
    "protocol_version",
    "request_id",
    "task",
    "source_locale",
    "target_locale",
    "instructions",
    "output_contract",
    "segments",
    "summary"
  ],
  "properties": {
    "protocol_version": { "const": "0.1" },
    "request_id": { "type": "string", "minLength": 1 },
    "run_id": { "type": ["string", "null"] },
    "task": { "const": "llm_translation_reflection" },
    "source_locale": { "type": "string", "minLength": 1 },
    "target_locale": { "type": "string", "minLength": 1 },
    "instructions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "output_contract": { "type": "object", "additionalProperties": true },
    "deterministic_findings": {
      "type": "array",
      "items": { "type": "object", "additionalProperties": true }
    },
    "segments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["segment_id", "source", "target"],
        "properties": {
          "segment_id": { "type": "string", "minLength": 1 },
          "source_path": { "type": "string" },
          "source": { "type": "string" },
          "target": { "type": "string" },
          "context": { "type": "object", "additionalProperties": true },
          "constraints": { "type": "object", "additionalProperties": true }
        },
        "additionalProperties": true
      }
    },
    "summary": { "type": "object", "additionalProperties": true }
  },
  "additionalProperties": true
}
