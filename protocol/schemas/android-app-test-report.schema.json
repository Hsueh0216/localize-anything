{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://localize-anything.dev/schemas/android-app-test-report.schema.json",
  "title": "Localize Anything Android App Test Report",
  "type": "object",
  "required": [
    "protocol_version",
    "evidence_channels",
    "run_id",
    "status",
    "android",
    "generation",
    "source_preservation",
    "summary",
    "artifacts",
    "next_actions"
  ],
  "properties": {
    "protocol_version": { "const": "0.1" },
    "evidence_channels": {
      "type": "array",
      "items": { "enum": ["runtime", "agent", "adapter", "human", "llm"] }
    },
    "run_id": { "type": "string", "minLength": 1 },
    "status": { "enum": ["pass", "fail"] },
    "android": {
      "type": "object",
      "required": [
        "project_root",
        "app_copy",
        "source_file",
        "source_files",
        "target_locale",
        "target_file",
        "target_files",
        "adapter"
      ],
      "properties": {
        "project_root": { "type": "string", "minLength": 1 },
        "app_copy": { "type": "string", "minLength": 1 },
        "source_file": { "type": "string", "minLength": 1 },
        "source_files": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        },
        "target_locale": { "type": "string", "minLength": 1 },
        "target_file": { "type": "string", "minLength": 1 },
        "target_files": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        },
        "adapter": { "const": "core.android-strings" }
      },
      "additionalProperties": true
    },
    "generation": {
      "type": "object",
      "required": ["mode", "quality_claim", "purpose"],
      "additionalProperties": true
    },
    "source_preservation": {
      "type": "object",
      "required": [
        "source_file_before",
        "source_file_after",
        "target_file_before",
        "target_file_after",
        "original_project_mutated"
      ],
      "properties": {
        "original_project_mutated": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "summary": {
      "type": "object",
      "required": [
        "segment_count",
        "batch_count",
        "output_count",
        "agent_status",
        "delivery_decision_status",
        "real_generation_required",
        "real_generation_satisfied",
        "apply_created",
        "apply_replaced",
        "localized_file_count",
        "post_apply_qa_status",
        "post_apply_blocking_count",
        "post_apply_warning_count"
      ],
      "additionalProperties": true
    },
    "artifacts": { "type": "object", "additionalProperties": true },
    "next_actions": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": true
}
