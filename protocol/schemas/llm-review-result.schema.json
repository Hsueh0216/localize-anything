{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://localize-anything.dev/schemas/llm-review-result.schema.json",
  "title": "Localize Anything LLM Review Result",
  "type": "object",
  "required": ["protocol_version", "evidence_channels", "request_id", "status", "summary", "issues", "validation_items"],
  "properties": {
    "protocol_version": { "const": "0.1" },
    "evidence_channels": {
      "type": "array",
      "items": { "enum": ["llm", "runtime"] }
    },
    "request_id": { "type": "string", "minLength": 1 },
    "status": { "enum": ["pass", "pass_with_warnings", "fail"] },
    "summary": { "type": "object", "additionalProperties": true },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["segment_id", "severity", "category", "message", "confidence", "channel"],
        "properties": {
          "segment_id": { "type": "string", "minLength": 1 },
          "severity": { "enum": ["blocking", "warning", "note"] },
          "category": { "type": "string", "minLength": 1 },
          "message": { "type": "string" },
          "confidence": { "type": "string", "minLength": 1 },
          "channel": { "const": "llm" },
          "suggested_target": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "validation_items": {
      "type": "array",
      "items": { "type": "object", "additionalProperties": true }
    }
  },
  "additionalProperties": true
}
