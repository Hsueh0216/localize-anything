{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://localize-anything.dev/schemas/work-packet.schema.json",
  "title": "Localize Anything Working Context Packet",
  "type": "object",
  "required": [
    "protocol_version",
    "packet_id",
    "batch_id",
    "source_locale",
    "target_locale",
    "operating_mode",
    "reference_policy",
    "segments",
    "memory",
    "budget"
  ],
  "properties": {
    "protocol_version": { "const": "0.1" },
    "packet_id": { "type": "string", "minLength": 1 },
    "batch_id": { "type": "string", "minLength": 1 },
    "source_locale": { "type": "string", "minLength": 1 },
    "target_locale": { "type": "string", "minLength": 1 },
    "operating_mode": {
      "enum": ["blind_benchmark", "greenfield_localization", "existing_locale_maintenance", "rewrite_or_harmonization"]
    },
    "reference_policy": {
      "enum": ["blind", "style_only", "tm_assisted", "preserve_existing"]
    },
    "mode_contract": { "type": "object", "additionalProperties": true },
    "segments": { "type": "array", "minItems": 1, "items": { "$ref": "segment.schema.json" } },
    "memory": {
      "type": "object",
      "required": ["context_sections", "glossary", "translation_memory"],
      "properties": {
        "context_sections": { "type": "array", "items": { "type": "object" } },
        "glossary": { "type": "array", "items": { "type": "object" } },
        "translation_memory": { "type": "array", "items": { "type": "object" } }
      },
      "additionalProperties": true
    },
    "budget": {
      "type": "object",
      "required": ["estimated_tokens", "limit_tokens", "estimation"],
      "properties": {
        "estimated_tokens": { "type": "integer", "minimum": 0 },
        "limit_tokens": { "type": "integer", "minimum": 1 },
        "estimation": { "enum": ["exact", "estimated"] },
        "trimmed": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
