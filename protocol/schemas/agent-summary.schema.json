{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://localize-anything.dev/schemas/agent-summary.schema.json",
  "title": "Localize Anything Agent Summary",
  "type": "object",
  "required": [
    "protocol_version",
    "evidence_channels",
    "run_id",
    "status",
    "project",
    "agent",
    "routing",
    "parallelization",
    "reflection",
    "delivery",
    "runs",
    "summary",
    "artifacts",
    "next_actions"
  ],
  "properties": {
    "protocol_version": { "const": "0.1" },
    "evidence_channels": {
      "type": "array",
      "items": { "enum": ["agent", "runtime", "human", "llm"] }
    },
    "run_id": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "minLength": 1 },
    "project": {
      "type": "object",
      "required": ["root", "source_locale", "target_locale", "mode", "operating_mode", "reference_policy"],
      "properties": {
        "root": { "type": "string", "minLength": 1 },
        "source_locale": { "type": "string", "minLength": 1 },
        "target_locale": { "type": "string", "minLength": 1 },
        "mode": { "type": "string", "minLength": 1 },
        "operating_mode": {
          "enum": ["blind_benchmark", "greenfield_localization", "existing_locale_maintenance", "rewrite_or_harmonization"]
        },
        "reference_policy": {
          "enum": ["blind", "style_only", "tm_assisted", "preserve_existing"]
        }
      },
      "additionalProperties": true
    },
    "agent": { "type": "object", "additionalProperties": true },
    "routing": { "type": "object", "additionalProperties": true },
    "parallelization": { "type": "object", "additionalProperties": true },
    "reflection": { "type": "object", "additionalProperties": true },
    "delivery": { "type": "object", "additionalProperties": true },
    "runs": { "type": "object", "additionalProperties": true },
    "summary": { "type": "object", "additionalProperties": true },
    "artifacts": { "type": "object", "additionalProperties": true },
    "next_actions": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": true
}
